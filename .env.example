GEMINI_API_KEY=your_gemini_api_key_here

# xAI Aurora image generation (get key at console.x.ai)
XAI_API_KEY=your_xai_api_key_here

# Kling 1.6 video generation (get keys at platform.klingai.com → API Keys)
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# Local product images folder (optional, no need to copy to public/)
PRODUCT_IMAGES_DIR=/path/to/your/product/images
