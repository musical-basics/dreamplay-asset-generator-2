# DreamPlay Asset Generator gitignore
.env.local
.env

# Next.js
.next/
out/
build/

# Dependencies
node_modules/
.pnpm-store/

# Logs
*.log
npm-debug.log*

# Generated assets (keep the folder, ignore generated files)
public/generated/**
!public/generated/.gitkeep

# Local product image library (large files, not committed)
public/product-images/**
!public/product-images/.gitkeep

# Repomix output
repomix-output*.xml
repomix-output*.txt
*.repomix.xml

# macOS
.DS_Store

# IDE
.vscode/
